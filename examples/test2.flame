

func swap(ref i32 a, ref i32 b) void {
    i32 c = b;
    b = a;
    a = c;
    //return;
}

struct cool {
    i32 x=0;
    vec i32 a=[1];
    i32[1] b = [1];
    func inc(i32 i) void {
        x+=i;
        return;
    }
};

func main() i32 {
    i32 f = -3;
    i32 d = -2;
    
    swap(f, d);
    print(f); // should be -2
    cool a;
    a.inc(1);
    print(a.a[0]);
    cool* c;
    c.inc(2);
    print(c.b[0]);
    return 0;
}